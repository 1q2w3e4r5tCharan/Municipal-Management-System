### Copy this file to .env and fill in real values. DO NOT commit your .env file to git.
# Example env vars for SMTP notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password-here
FROM_EMAIL=no-reply@example.com
SMTP_USE_TLS=true
# Optional comma-separated public recipients to CC for notifications
PUBLIC_NOTIFICATION_LIST=public1@example.com,public2@example.com
